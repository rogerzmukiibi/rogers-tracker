# Rogers Tracker — environment configuration
# Copy this file to .env and edit as needed.
# All values below are the defaults; only override what you need to change.

# Path to the SQLite database file.
# In Docker this is mounted as a volume at /app/data/tracker.db.
# DB_PATH=data/tracker.db

# Server bind address and port.
# APP_HOST=0.0.0.0
# APP_PORT=8000

# Set to true during local development to enable auto-reload.
# Never set in production/Docker.
# DEBUG=false
